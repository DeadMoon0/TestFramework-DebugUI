<Window x:Name="window" x:Class="TestFrameworkDebugUI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:TestFrameworkDebugUI"
        xmlns:timelineBoard="clr-namespace:TestFrameworkDebugUI.Controls.TimelineBoard"
        mc:Ignorable="d"
        Title="TestFrameworkDebugger" Height="650" Width="1100" WindowStyle="None" Background="#01000000"
        MinHeight="650" MinWidth="1100" AllowsTransparency="True"
        SourceInitialized="Window_SourceInitialized" StateChanged="Window_StateChanged" Closing="Window_Closing">
    <!--Background="#7F202020"-->
    <!--<Window.CommandBindings>
        <CommandBinding Command="{x:Static local:MainWindow.SaveCommand}" 
                     Executed="Save"/>
    </Window.CommandBindings>-->
