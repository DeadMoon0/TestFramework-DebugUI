<UserControl x:Name="userControl" x:Class="WPFCommon.DropDown.UC_DD_Input"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPFCommon.DropDown"
             mc:Ignorable="d" Height="25.96">
    <Border x:Name="border" CornerRadius="5">
        <Grid>
            <Grid.ColumnDefinitions>
                <ColumnDefinition x:Name="cdIcon" Width="0"/>
                <ColumnDefinition Width="auto"/>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="auto"/>
            </Grid.ColumnDefinitions>
            <Viewbox x:Name="vbImage" Margin="5">
                <Image x:Name="iIcon" Source="{Binding Path=Icon,ElementName=userControl}"/>
            </Viewbox>
            <Viewbox x:Name="vbIcon" Margin="5" Visibility="Collapsed"/>
            <Label x:Name="lText" Grid.Column="1" VerticalAlignment="Center" Foreground="White" Content="{Binding Path=Text,ElementName=userControl}"></Label>
            <Border Grid.Column="2" CornerRadius="5" Background="#19000000" Margin="2.5">
                <TextBox x:Name="tbValue" VerticalAlignment="Center" Foreground="White" Text="{Binding Path=Value,ElementName=userControl, Mode=TwoWay}" Background="{x:Null}" BorderBrush="{x:Null}" CaretBrush="White"></TextBox>
            </Border>
            <Border x:Name="btClick" Grid.Column="3" Margin="2.5" Background="#19000000" CornerRadius="5" Cursor="Hand" MouseLeftButtonUp="border_MouseLeftButtonUp">
                <Viewbox>
                    <Label Foreground="White" FontWeight="Bold">OK</Label>
                </Viewbox>
            </Border>
        </Grid>
    </Border>
</UserControl>
