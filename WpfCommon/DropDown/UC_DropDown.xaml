<UserControl x:Class="WPFCommon.DropDown.UC_DropDown"
       xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
       xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
       xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
       xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
       xmlns:local="clr-namespace:WPFCommon.DropDown">
    <Border x:Name="border" Padding="5" CornerRadius="5" Background="#FF232323" Margin="10"
            MinWidth="150">
        <Border.Effect>
            <DropShadowEffect BlurRadius="10" ShadowDepth="0.5" Direction="270"/>
        </Border.Effect>
    </Border>
</UserControl>