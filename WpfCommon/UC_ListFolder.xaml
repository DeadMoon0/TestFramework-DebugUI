<UserControl x:Name="usercontrol" x:Class="WPFCommon.UC_ListFolder"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006" 
             xmlns:d="http://schemas.microsoft.com/expression/blend/2008" 
             xmlns:local="clr-namespace:WPFCommon"
             mc:Ignorable="d" d:DesignWidth="100">
    <Border CornerRadius="5" Background="#0C000000" Margin="0 5 0 0">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="auto"/>
                <RowDefinition Height="*"/>
            </Grid.RowDefinitions>
            <Button x:Name="bt" Grid.Row="0" Cursor="Hand" Click="bt_Click">
                <Button.Style>
                    <Style TargetType="{x:Type Button}">
                        <Setter Property="Template">
                            <Setter.Value>
                                <ControlTemplate TargetType="{x:Type Button}">
                                    <Border Background="{TemplateBinding Background}">
                                        <ContentPresenter HorizontalAlignment="Stretch" VerticalAlignment="Center"/>
                                    </Border>
                                </ControlTemplate>
                            </Setter.Value>
                        </Setter>
                        <Setter Property="Background" Value="#26000000"/>
                        <Style.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Trigger.EnterActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)"
From="#26000000" To="#3F000000"
Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.EnterActions>
                                <Trigger.ExitActions>
                                    <BeginStoryboard>
                                        <Storyboard>
                                            <ColorAnimation Storyboard.TargetProperty="(Button.Background).(SolidColorBrush.Color)"
From="#3F000000" To="#26000000"
Duration="0:0:0.2"/>
                                        </Storyboard>
                                    </BeginStoryboard>
                                </Trigger.ExitActions>
                            </Trigger>
                        </Style.Triggers>
                        <Style.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Style.Resources>
                    </Style>
                </Button.Style>
                <Grid Height="26">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="auto"/>
                    </Grid.ColumnDefinitions>
                    <Viewbox Margin="5">
                        <Canvas Height="448" Width="448" RenderTransformOrigin="0.5 0.5">
                            <Canvas.Style>
                                <Style TargetType="Canvas">
                                    <Setter Property="RenderTransform">
                                        <Setter.Value>
                                            <RotateTransform Angle="0"/>
                                        </Setter.Value>
                                    </Setter>
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding ElementName=usercontrol, Path=IsOpen}" Value="False">
                                            <DataTrigger.EnterActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(Canvas.RenderTransform).(RotateTransform.Angle)"
                                                                         From="0" To="-90"
                                                                         Duration="0:0:0.2"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.EnterActions>
                                            <DataTrigger.ExitActions>
                                                <BeginStoryboard>
                                                    <Storyboard>
                                                        <DoubleAnimation Storyboard.TargetProperty="(Canvas.RenderTransform).(RotateTransform.Angle)"
                         From="-90" To="0"
                         Duration="0:0:0.2"/>
                                                    </Storyboard>
                                                </BeginStoryboard>
                                            </DataTrigger.ExitActions>
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </Canvas.Style>
                            <Path Fill="White" Data="M201.4 342.6c12.5 12.5 32.8 12.5 45.3 0l160-160c12.5-12.5 12.5-32.8 0-45.3s-32.8-12.5-45.3 0L224 274.7 86.6 137.4c-12.5-12.5-32.8-12.5-45.3 0s-12.5 32.8 0 45.3l160 160z"/>
                        </Canvas>
                    </Viewbox>
                    <Label Grid.Column="1" Foreground="White" FontSize="16" Padding="5 0 5 0" VerticalAlignment="Center" HorizontalAlignment="Left" Content="{Binding ElementName=usercontrol, Path=Title}"></Label>
                    <Label x:Name="lCount" Grid.Column="2" Foreground="Gray" FontWeight="Bold" Content="{Binding ElementName=spContent, Path=Children.Count}"></Label>
                </Grid>
            </Button>
            <Grid x:Name="gContent" Grid.Row="1">
                <local:ObservableStackPanel x:Name="spContent" Margin="5">
                    <!--<Label>C</Label>-->
                </local:ObservableStackPanel>
                <Label x:Name="lZCount" Foreground="Gray" HorizontalAlignment="Center" FontSize="10" Content="{Binding ElementName=usercontrol, Path=ZeroCountText}" Visibility="Collapsed"></Label>
            </Grid>
            
        </Grid>
    </Border>
</UserControl>